pipeline {
    agent any

    stages{

            stage('Build') {
                steps{
                     echo 'You are in a Building stage....'
        }
    }

    stage('Test') {
        steps {
            echo 'You are in a Test stage.....'
        }
    }

    stage('Deploy') {
        steps {
            echo 'You are in a deployment stage....'
        }
    }


    }

}